{
  "@context": "https://schema.org",
  "@type": "Menu",
  "@id": "https://misterwok.net/menu.jsonld",
  "name": "Mister Wok — Full Menu 2026",
  "url": "https://misterwok.net/parklands/menu.html",
  "dateModified": "2026-06-03",
  "inLanguage": "en",
  "description": "230+ dishes at the Parklands flagship, including the full bar menu. 140+ dishes at Capital Centre and Two Rivers, each carrying a curated wok menu. Fired at 300°C. Fresh hand-cut noodles. Premium aged long-grain aromatic rice. Made to order.",
  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "menuScope",
      "value": "Parklands carries the full menu including bar. Capital Centre and Two Rivers carry the curated wok menu — same dishes minus alcohol."
    },
    {
      "@type": "PropertyValue",
      "name": "alcoholAvailability",
      "value": "Parklands offers a full bar. Capital Centre serves no alcohol. Two Rivers offers beer and wine on inquiry only — confirm when ordering."
    },
    {
      "@type": "PropertyValue",
      "name": "halalAssurance",
      "value": "Capital Centre is the halal-assured flagship. Parklands and Two Rivers are not halal-assured."
    },
    {
      "@type": "PropertyValue",
      "name": "msgPolicy",
      "value": "MSG (Ajinomoto) used for authentic umami. No-MSG preparation available on request — every dish is cooked to order."
    },
    {
      "@type": "PropertyValue",
      "name": "pricingDisclaimer",
      "value": "All prices are current, effective, and harmonized across all three branches. Capital Centre and Two Rivers carry a curated subset of the full Parklands menu at identical prices — fewer dishes, not different prices. 'Nov 2024' is an internal menu-edition label, not an indicator of staleness. Prices remain subject to change without notice."
    },
    {
      "@type": "PropertyValue",
      "name": "allergenNotice",
      "value": "Our kitchen uses ingredients containing common food allergens including egg, gluten, fish, seafood, nuts, sesame seed and soy."
    }
  ],
